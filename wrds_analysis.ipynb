import wrds
import pandas as pd
import matplotlib.pyplot as plt

# Connect to WRDS
db = wrds.Connection(wrds_username="your_username")

# Parameters
permno = 14593
start = "2020-01-01"
end = "2024-12-31"

# Query CRSP Daily Data
query = f"""
select date, prc, ret, vol
from crsp.dsf
where permno = {permno}
and date between '{start}' and '{end}'
"""
df = db.raw_sql(query)
db.close()

# Data Cleaning
df["date"] = pd.to_datetime(df["date"])
df["price"] = df["prc"].abs()
df = df.dropna()

# Descriptive Statistics
print(df.describe())

# Plot Price Trend
plt.figure(figsize=(12, 5))
plt.plot(df["date"], df["price"])
plt.title(f"PERMNO {permno} Stock Price")
plt.xlabel("Date")
plt.ylabel("Price")
plt.show()

# Plot Return Distribution
plt.figure(figsize=(10, 4))
plt.hist(df["ret"], bins=60, alpha=0.7)
plt.title("Daily Return Distribution")
plt.xlabel("Daily Return")
plt.ylabel("Frequency")
plt.show()