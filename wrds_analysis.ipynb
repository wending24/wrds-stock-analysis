import wrds
import pandas as pd
import matplotlib.pyplot as plt

# Connect to WRDS
db = wrds.Connection(wrds_username="your_username")

# Parameters (multiple PERMNOs)
permno_list = [14593, 10078]
start = "2020-01-01"
end = "2024-12-31"

all_dfs = []
for permno in permno_list:
    query = f"""
        select date, permno, prc, ret, vol
        from crsp.dsf
        where permno = {permno}
        and date between '{start}' and '{end}'
    """
    df = db.raw_sql(query)
    all_dfs.append(df)

db.close()

df = pd.concat(all_dfs, ignore_index=True)
df["date"] = pd.to_datetime(df["date"])
df["price"] = df["prc"].abs()
df = df.dropna()

# Descriptive Statistics
print(df.describe())

# Plot Price Trend
plt.figure(figsize=(12, 5))
for pno in df['permno'].unique():
    sub = df[df['permno'] == pno]
    plt.plot(sub["date"], sub["price"], label=f"PERMNO {pno}")
plt.title("Stock Price by PERMNO")
plt.xlabel("Date")
plt.ylabel("Price")
plt.legend()
plt.show()

# Return Distribution
plt.figure(figsize=(10, 4))
plt.hist(df["ret"], bins=60, alpha=0.7)
plt.title("Daily Return Distribution")
plt.xlabel("Daily Return")
plt.ylabel("Frequency")
plt.show()